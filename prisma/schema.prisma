  INTERVIEW_DONE
  SELECTED
  OFFERED
  JOINED
  REJECTED
  DROPPED
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
}

enum LeaveStatus {
  PENDING
