  COMPLETED
}

enum ReviewCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUAL
}

enum ExitType {
  RESIGNATION
  TERMINATION
  RETIREMENT
  CONTRACT_END
  ABSCONDING
}

enum ExitStatus {
  INITIATED
  NOTICE_PERIOD
  CLEARANCE_PENDING
  FULL_FINAL_PENDING
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FieldTaskStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  FAILED
  DROPPED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum ILTStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum ExpenseCategory {
