generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String              @id @default(uuid())
  name                   String
  email                  String              @unique
  password               String
  role                   Role                @default(CLIENT)
  phone                  String?
  image                  String?
  isActive               Boolean             @default(true)
  createdAt              DateTime            @default(now())
  companyId              String?
  assignmentsAsAssigner  Assignment[]        @relation("AssignmentAssigner")
  assignmentsAsInspector Assignment[]        @relation("AssignmentInspector")
  employeeProfile        Employee?           @relation("EmployeeUser")
  inspections            Inspection[]
  leadsAssigned          Lead[]              @relation("LeadAssignee")
  leadsCreated           Lead[]              @relation("LeadCreator")
  leadActivities         LeadActivity[]      @relation("LeadActivityUser")
  leadDocsUploaded       LeadDocument[]      @relation("LeadDocUploader")
  leadFollowUpsCreated   LeadFollowUp[]      @relation("LeadFollowUpCreator")
  notifications          Notification[]
  hrApprovedReviews      PerformanceReview[] @relation("HRApprover")
  assignedProjects       ProjectManager[]    @relation("ProjectManagerAssigner")
  managedProjects        ProjectManager[]    @relation("ProjectManagers")
  company                Company?            @relation(fields: [companyId], references: [id])
}

model Company {
  id            String    @id @default(uuid())
  name          String
  address       String?
  contactPerson String?
  contactPhone  String?
  logoUrl       String?
  createdBy     String
  createdAt     DateTime  @default(now())
  branches      Branch[]
  projects      Project[]
  clients       User[]
}

model Project {
  id              String           @id @default(uuid())
  companyId       String
  name            String
  description     String?
  createdBy       String
  createdAt       DateTime         @default(now())
  defectColumns   Json?
  reportConfig    Json?
  alertConfig     AlertConfig?
  assignments     Assignment[]
  formTemplates   FormTemplate[]
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectManagers ProjectManager[]
}

model Assignment {
  id               String       @id @default(uuid())
  projectId        String
  inspectionBoyId  String
  assignedBy       String
  status           String       @default("active")
  recurrenceType   String       @default("none")
  recurrenceActive Boolean      @default(false)
  createdAt        DateTime     @default(now())
  assigner         User         @relation("AssignmentAssigner", fields: [assignedBy], references: [id])
  inspectionBoy    User         @relation("AssignmentInspector", fields: [inspectionBoyId], references: [id])
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inspections      Inspection[]

  @@index([inspectionBoyId])
  @@index([projectId])
  @@index([status])
}

model Inspection {
  id             String           @id @default(uuid())
  assignmentId   String
  status         String           @default("draft")
  submittedAt    DateTime?
  createdAt      DateTime         @default(now())
  approvedAt     DateTime?
  approvedBy     String?
  reviewerNotes  String?
  submittedBy    String
  paperFormPhoto String?
  sentBackAt     DateTime?
  sentBackCount  Int              @default(0)
  gpsLocation    String?
  startedAt      DateTime?
  signature      String?
  assignment     Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submitter      User             @relation(fields: [submittedBy], references: [id])
  responses      InspectionData[]
  shareableLink  ShareableLink?

  @@index([status])
  @@index([assignmentId])
  @@index([submittedBy])
  @@index([submittedAt])
  @@index([approvedAt])
}

model InspectionData {
  id           String       @id @default(uuid())
  inspectionId String
  fieldId      String
  value        String?
  field        FormTemplate @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  inspection   Inspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([fieldId])
}

model FormTemplate {
  id           String           @id @default(uuid())
  projectId    String
  fieldLabel   String
  fieldType    String
  options      String?
  defaultValue String?
  isRequired   Boolean          @default(false)
  category     String           @default("FIXED")
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses    InspectionData[]

  @@index([projectId])
}

model ProjectManager {
  id         String   @id @default(uuid())
  projectId  String
  managerId  String
  assignedBy String
  createdAt  DateTime @default(now())
  assigner   User     @relation("ProjectManagerAssigner", fields: [assignedBy], references: [id])
  manager    User     @relation("ProjectManagers", fields: [managerId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, managerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model ShareableLink {
  id           String     @id @default(uuid())
  inspectionId String     @unique
  token        String     @unique @default(uuid())
  expiresAt    DateTime?
  createdBy    String
  viewCount    Int        @default(0)
  createdAt    DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([token])
}

model AlertConfig {
  id              String   @id @default(uuid())
  projectId       String   @unique
  defectThreshold Float    @default(5.0)
  notifyManager   Boolean  @default(true)
  notifyAdmin     Boolean  @default(true)
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Lead {
  id                  String         @id @default(uuid())
  candidateName       String
  phone               String
  email               String?
  city                String?
  position            String
  experience          Float?
  currentCompany      String?
  qualification       String?
  skills              String?
  expectedSalary      Float?
  currentSalary       Float?
  interviewDate       DateTime?
  interviewMode       String?
  source              String
  status              LeadStatus     @default(NEW_LEAD)
  priority            LeadPriority   @default(MEDIUM)
  score               LeadScore      @default(WARM)
  interviewerId       String?
  interviewFeedback   String?
  interviewResult     String?
  assignedTo          String?
  notes               String?
  nextFollowUp        DateTime?
  locality            String?
  gender              String?
  languages           String?
  age                 Int?
  course              String?
  specialization      String?
  collegeName         String?
  courseStartYear     String?
  courseEndYear       String?
  previousDesignation String?
  previousCompany     String?
  resumeUrl           String?
  profileUrl          String?
  englishLevel        String?
  levelOfExperience   String?
  createdBy           String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  assignee            User?          @relation("LeadAssignee", fields: [assignedTo], references: [id])
  creator             User           @relation("LeadCreator", fields: [createdBy], references: [id])
  activities          LeadActivity[]
  documents           LeadDocument[]
  followUps           LeadFollowUp[]

  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

model LeadDocument {
  id         String   @id @default(uuid())
  leadId     String
  docType    String
  fileName   String
  url        String
  verified   String   @default("PENDING")
  uploadedBy String
  createdAt  DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploader   User     @relation("LeadDocUploader", fields: [uploadedBy], references: [id])

  @@index([leadId])
}

model LeadFollowUp {
  id          String    @id @default(uuid())
  leadId      String
  type        String
  note        String?
  scheduledAt DateTime
  completedAt DateTime?
  status      String    @default("PENDING")
  createdBy   String
  createdAt   DateTime  @default(now())
  creator     User      @relation("LeadFollowUpCreator", fields: [createdBy], references: [id])
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([scheduledAt])
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  type      String
  content   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation("LeadActivityUser", fields: [userId], references: [id])

  @@index([leadId])
}

model Ticket {
  id          String          @id @default(uuid())
  ticketNo    String          @unique
  title       String
  description String
  category    String
  priority    TicketPriority  @default(MEDIUM)
  status      TicketStatus    @default(OPEN)
  raisedBy    String
  assignedTo  String?
  employeeId  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  dueDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  comments    TicketComment[]

  @@index([status])
  @@index([raisedBy])
  @@index([assignedTo])
  @@index([createdAt])
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Branch {
  id          String       @id @default(uuid())
  name        String
  address     String?
  city        String?
  state       String?
  companyId   String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]
  employees   Employee[]
  sites       Site[]
}

model Department {
  id          String     @id @default(uuid())
  name        String
  description String?
  branchId    String
  headId      String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  branch      Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employees   Employee[]
}

model Site {
  id               String       @id @default(uuid())
  name             String
  code             String?      @unique
  address          String
  city             String?
  state            String?
  pincode          String?
  clientName       String?
  clientId         String?
  branchId         String
  latitude         Float?
  longitude        Float?
  radius           Float        @default(100)
  manpowerRequired Int          @default(1)
  contactPerson    String?
  contactPhone     String?
  siteType         String?
  shift            String?
  isActive         Boolean      @default(true)
  createdBy        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  attendances      Attendance[]
  deployments      Deployment[]
  branch           Branch       @relation(fields: [branchId], references: [id])

  @@index([isActive])
  @@index([clientId])
}

model Employee {
  id                     String                    @id @default(uuid())
  employeeId             String                    @unique
  firstName              String
  lastName               String
  email                  String?
  phone                  String
  alternatePhone         String?
  dateOfBirth            DateTime?
  gender                 String?
  address                String?
  city                   String?
  state                  String?
  pincode                String?
  aadharNumber           String?
  panNumber              String?
  bankAccountNumber      String?
  bankIFSC               String?
  bankName               String?
  photo                  String?
  designation            String?
  departmentId           String?
  branchId               String?
  dateOfJoining          DateTime?
  dateOfLeaving          DateTime?
  status                 EmployeeStatus            @default(ACTIVE)
  employmentType         String                    @default("Full-time")
  employeeCategory       String                    @default("STAFF")
  salaryType             String?
  basicSalary            Float                     @default(0)
  dailyRate              Float?
  managerId              String?
  notes                  String?
  isKycVerified          Boolean                   @default(false)
  kycRejectionNote       String?
  onboardingToken        String?                   @unique
  userId                 String?                   @unique
  createdBy              String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  middleName             String?
  nameAsPerAadhar        String?
  fathersName            String?
  bloodGroup             String?
  maritalStatus          String?
  marriageDate           DateTime?
  nationality            String?                   @default("Indian")
  religion               String?
  caste                  String?
  uan                    String?
  pfNumber               String?
  esiNumber              String?
  labourCardNo           String?
  labourCardExpDate      DateTime?
  contractFrom           DateTime?
  contractPeriodDays     Int?
  contractorCode         String?
  workOrderNumber        String?
  workOrderFrom          DateTime?
  workOrderTo            DateTime?
  workSkill              String?
  natureOfWork           String?
  categoryCode           String?
  employmentTypeCode     String?
  emergencyContact1Name  String?
  emergencyContact1Phone String?
  emergencyContact2Name  String?
  emergencyContact2Phone String?
  permanentAddress       String?
  permanentCity          String?
  permanentState         String?
  permanentPincode       String?
  isBackgroundChecked    Boolean                   @default(false)
  backgroundCheckRemark  String?
  isMedicalDone          Boolean                   @default(false)
  medicalRemark          String?
  safetyGoggles          Boolean                   @default(false)
  safetyGogglesDate      DateTime?
  safetyGloves           Boolean                   @default(false)
  safetyGlovesDate       DateTime?
  safetyHelmet           Boolean                   @default(false)
  safetyHelmetDate       DateTime?
  safetyMask             Boolean                   @default(false)
  safetyMaskDate         DateTime?
  safetyJacket           Boolean                   @default(false)
  safetyJacketDate       DateTime?
  safetyEarMuffs         Boolean                   @default(false)
  safetyEarMuffsDate     DateTime?
  safetyShoes            Boolean                   @default(false)
  safetyShoesDate        DateTime?
  bankBranch             String?
  advances               AdvanceAndReimbursement[]
  attendances            Attendance[]
  enrollments            CourseEnrollment[]
  courseFeedbacks        CourseFeedback[]
  deployments            Deployment[]
  branch                 Branch?                   @relation(fields: [branchId], references: [id])
  department             Department?               @relation(fields: [departmentId], references: [id])
  user                   User?                     @relation("EmployeeUser", fields: [userId], references: [id])
  assets                 EmployeeAsset[]
  documents              EmployeeDocument[]
  employeeSalary         EmployeeSalary?
  exitRequest            ExitRequest?
  checkIns               FieldCheckIn[]
  fieldTasks             FieldTask[]
  hrDocuments            HRDocument[]
  iltAttendances         ILTAttendance[]
  leaves                 Leave[]
  onboardingRecord       OnboardingRecord?
  onboardingTasks        OnboardingTask[]
  pips                   PIP[]
  payrolls               Payroll[]
  reviews                PerformanceReview[]
  policyAcknowledgments  PolicyAcknowledgment[]

  @@index([branchId])
  @@index([status])
}

model EmployeeDocument {
  id              String   @id @default(uuid())
  employeeId      String
  type            String
  fileName        String
  fileUrl         String
  status          String   @default("PENDING")
  rejectionReason String?
  verifiedBy      String?
  uploadedAt      DateTime @default(now())
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeSalary {
  id                String   @id @default(uuid())
  employeeId        String   @unique
  basic             Float    @default(0)
  da                Float    @default(0)
  washing           Float    @default(0)
  conveyance        Float    @default(0)
  leaveWithWages    Float    @default(0)
  otherAllowance    Float    @default(0)
  otRatePerHour     Float    @default(170)
  canteenRatePerDay Float    @default(55)
  ctcAnnual         Float    @default(0)
  ctcMonthly        Float    @default(0)
  hra               Float    @default(0)
  specialAllowance  Float    @default(0)
  isPfEligible      Boolean  @default(true)
  isEsiEligible     Boolean  @default(true)
  isPtEligible      Boolean  @default(true)
  lwfState          String?
  serviceChargeRate Float    @default(0)
  status            String   @default("APPROVED")
  proposedBy        String   @default("system")
  approvedBy        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Deployment {
  id         String    @id @default(uuid())
  employeeId String
  siteId     String
  startDate  DateTime
  endDate    DateTime?
  shift      String?
  role       String?
  isActive   Boolean   @default(true)
  relievedAt DateTime?
  notes      String?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  site       Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([siteId])
  @@index([isActive])
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  siteId      String?
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  checkInLat  Float?
  checkInLng  Float?
  checkOutLat Float?
  checkOutLng Float?
  status      String    @default("PRESENT")
  overtimeHrs Float     @default(0)
  workingHrs  Float     @default(0)
  remarks     String?
  markedBy    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])
  site        Site?     @relation(fields: [siteId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
}

model Leave {
  id              String      @id @default(uuid())
  employeeId      String
  type            String
  startDate       DateTime
  endDate         DateTime
  days            Float
  reason          String?
  status          LeaveStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  employee        Employee    @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model SalaryStructure {
  id           String   @id @default(uuid())
  name         String
  basicPercent Float    @default(50)
  hraPercent   Float    @default(20)
  pfEmployee   Float    @default(12)
  pfEmployer   Float    @default(12)
  esiEmployee  Float    @default(0.75)
  esiEmployer  Float    @default(3.25)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Payroll {
  id                  String        @id @default(uuid())
  employeeId          String
  payrollRunId        String?
  month               Int
  year                Int
  basicFull           Float         @default(0)
  daFull              Float         @default(0)
  hraFull             Float         @default(0)
  washingFull         Float         @default(0)
  conveyanceFull      Float         @default(0)
  lwwFull             Float         @default(0)
  bonusFull           Float         @default(0)
  otherFull           Float         @default(0)
  grossFullMonth      Float         @default(0)
  basicSalary         Float         @default(0)
  da                  Float         @default(0)
  hra                 Float         @default(0)
  washing             Float         @default(0)
  conveyance          Float         @default(0)
  lwwEarned           Float         @default(0)
  bonus               Float         @default(0)
  allowances          Float         @default(0)
  otDays              Float         @default(0)
  overtimePay         Float         @default(0)
  productionIncentive Float         @default(0)
  grossSalary         Float         @default(0)
  pfEmployee          Float         @default(0)
  pfEmployer          Float         @default(0)
  esiEmployee         Float         @default(0)
  esiEmployer         Float         @default(0)
  pt                  Float         @default(0)
  lwf                 Float         @default(0)
  tds                 Float         @default(0)
  canteenDays         Int           @default(0)
  canteen             Float         @default(0)
  penalty             Float         @default(0)
  advance             Float         @default(0)
  otherDeductions     Float         @default(0)
  totalDeductions     Float         @default(0)
  netSalary           Float         @default(0)
  ctc                 Float         @default(0)
  workingDays         Int           @default(26)
  presentDays         Int           @default(26)
  leaveDays           Float         @default(0)
  lwpDays             Float         @default(0)
  overtimeHrs         Float         @default(0)
  overtimeRate        Float         @default(0)
  siteId              String?
  status              PayrollStatus @default(DRAFT)
  processedAt         DateTime?
  processedBy         String?
  paidAt              DateTime?
  paidBy              String?
  remarks             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  employee            Employee      @relation(fields: [employeeId], references: [id])
  payrollRun          PayrollRun?   @relation(fields: [payrollRunId], references: [id])

  @@unique([employeeId, month, year])
  @@index([month, year])
  @@index([status])
  @@index([employeeId])
  @@index([payrollRunId])
}

model PayrollRun {
  id               String        @id @default(uuid())
  month            Int
  year             Int
  status           PayrollStatus @default(DRAFT)
  lockedAt         DateTime?
  processedBy      String
  totalGross       Float         @default(0)
  totalNet         Float         @default(0)
  totalPfEmployer  Float         @default(0)
  totalEsiEmployer Float         @default(0)
  totalLwf         Float         @default(0)
  totalTds         Float         @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  payrolls         Payroll[]

  @@unique([month, year])
  @@index([status])
}

model StatutoryChallan {
  id          String    @id @default(uuid())
  type        String
  month       Int
  year        Int
  trrnNumber  String?
  amount      Float
  paymentDate DateTime?
  status      String    @default("PENDING")
  documentUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([month, year])
}

model AdvanceAndReimbursement {
  id            String        @id @default(uuid())
  employeeId    String
  type          String
  amount        Float
  monthToImpact Int
  yearToImpact  Int
  reason        String?
  status        AdvanceStatus @default(PENDING)
  approvedBy    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  employee      Employee      @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([monthToImpact, yearToImpact])
}

model Asset {
  id           String          @id @default(uuid())
  assetCode    String          @unique
  name         String
  category     String
  description  String?
  serialNo     String?
  quantity     Int             @default(1)
  available    Int             @default(1)
  condition    AssetCondition  @default(NEW)
  purchaseDate DateTime?
  purchaseCost Float?
  vendor       String?
  location     String?
  isActive     Boolean         @default(true)
  createdBy    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  assignments  EmployeeAsset[]

  @@index([category])
  @@index([isActive])
}

model EmployeeAsset {
  id              String          @id @default(uuid())
  employeeId      String
  assetId         String
  issuedAt        DateTime        @default(now())
  issuedBy        String?
  returnedAt      DateTime?
  returnedTo      String?
  condition       AssetCondition  @default(GOOD)
  returnCondition AssetCondition?
  notes           String?
  isActive        Boolean         @default(true)
  asset           Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([assetId])
  @@index([isActive])
}

model OnboardingRecord {
  id          String           @id @default(uuid())
  employeeId  String           @unique
  status      OnboardingStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  assignedTo  String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tasks       OnboardingTask[]

  @@index([status])
}

model OnboardingTask {
  id           String           @id @default(uuid())
  onboardingId String
  employeeId   String
  title        String
  description  String?
  category     String
  status       TaskStatus       @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  completedBy  String?
  assignedTo   String?
  order        Int              @default(0)
  isRequired   Boolean          @default(true)
  createdAt    DateTime         @default(now())
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  onboarding   OnboardingRecord @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@index([employeeId])
  @@index([status])
}

model OnboardingChecklist {
  id          String   @id @default(uuid())
  name        String
  description String?
  tasks       Json
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model PerformanceReview {
  id                   String       @id @default(uuid())
  employeeId           String
  reviewerId           String
  cycle                ReviewCycle
  periodStart          DateTime
  periodEnd            DateTime
  status               ReviewStatus @default(DRAFT)
  overallRating        Float?
  strengths            String?
  improvements         String?
  managerComments      String?
  employeeComments     String?
  promotionRecommended Boolean      @default(false)
  incrementPercent     Float?
  selfRating           Float?
  selfComments         String?
  hrApprovedAt         DateTime?
  hrApprovedBy         String?
  bonusPercent         Float?
  performanceRank      String?
  incentiveAmount      Float?
  bonusNote            String?
  pipRequired          Boolean      @default(false)
  submittedAt          DateTime?
  acknowledgedAt       DateTime?
  completedAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  kpis                 KPI[]
  kras                 KRA[]
  pip                  PIP?
  employee             Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  hrApprover           User?        @relation("HRApprover", fields: [hrApprovedBy], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([cycle])
}

model KRA {
  id          String            @id @default(uuid())
  reviewId    String
  title       String
  description String?
  weightage   Float             @default(25)
  kpis        KPI[]
  review      PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model KPI {
  id          String            @id @default(uuid())
  reviewId    String
  kraId       String?
  title       String
  description String?
  target      Float             @default(0)
  actual      Float?            @default(0)
  weightage   Float             @default(10)
  rating      Float?
  remarks     String?
  kra         KRA?              @relation(fields: [kraId], references: [id])
  review      PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([kraId])
}

model PIP {
  id           String            @id @default(uuid())
  reviewId     String            @unique
  employeeId   String
  startDate    DateTime
  endDate      DateTime
  goals        String
  status       String            @default("ACTIVE")
  managerNotes String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  employee     Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  review       PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model KPITemplate {
  id          String   @id @default(uuid())
  role        String
  kraTitle    String
  kpiTitle    String
  description String?
  targetHint  String?
  weightage   Float    @default(10)
  createdAt   DateTime @default(now())
}

model ExitRequest {
  id               String              @id @default(uuid())
  employeeId       String              @unique
  exitType         ExitType
  status           ExitStatus          @default(INITIATED)
  resignationDate  DateTime
  lastWorkingDate  DateTime?
  noticePeriodDays Int                 @default(30)
  reason           String?
  hrComments       String?
  fnfAmount        Float?
  fnfPaidAt        DateTime?
  fnfPaidBy        String?
  initiatedBy      String
  approvedBy       String?
  approvedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  clearanceTasks   ExitClearanceTask[]
  employee         Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([exitType])
}

model ExitClearanceTask {
  id          String      @id @default(uuid())
  exitId      String
  title       String
  department  String
  status      String      @default("PENDING")
  dueDate     DateTime?
  completedAt DateTime?
  completedBy String?
  remarks     String?
  order       Int         @default(0)
  exitRequest ExitRequest @relation(fields: [exitId], references: [id], onDelete: Cascade)

  @@index([exitId])
}

model FieldTask {
  id            String          @id @default(uuid())
  taskNo        String          @unique
  title         String
  description   String?
  employeeId    String
  siteId        String?
  priority      TaskPriority    @default(MEDIUM)
  status        FieldTaskStatus @default(ASSIGNED)
  dueDate       DateTime
  dueTime       String?
  completedAt   DateTime?
  completedNote String?
  assignedBy    String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([dueDate])
}

model FieldCheckIn {
  id               String   @id @default(uuid())
  employeeId       String
  siteId           String?
  latitude         Float
  longitude        Float
  accuracy         Float?
  checkedInAt      DateTime @default(now())
  notes            String?
  isGeofenced      Boolean  @default(false)
  distanceFromSite Float?
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([checkedInAt])
}

model Policy {
  id              String                 @id @default(uuid())
  title           String
  description     String?
  category        String
  fileUrl         String?
  isRequired      Boolean                @default(true)
  isActive        Boolean                @default(true)
  createdBy       String?
  createdAt       DateTime               @default(now())
  acknowledgments PolicyAcknowledgment[]

  @@index([category])
  @@index([isActive])
}

model PolicyAcknowledgment {
  id             String   @id @default(uuid())
  policyId       String
  employeeId     String
  acknowledgedAt DateTime @default(now())
  ipAddress      String?
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy         Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, employeeId])
  @@index([employeeId])
  @@index([policyId])
}

model ILTSession {
  id           String          @id @default(uuid())
  title        String
  description  String?
  instructorId String
  courseId     String?
  location     String?
  startTime    DateTime
  endTime      DateTime
  maxSeats     Int             @default(20)
  status       ILTStatus       @default(SCHEDULED)
  materialsUrl String?
  feedbackForm Json?
  createdBy    String?
  createdAt    DateTime        @default(now())
  attendances  ILTAttendance[]

  @@index([status])
  @@index([instructorId])
  @@index([startTime])
}

model ILTAttendance {
  id         String     @id @default(uuid())
  sessionId  String
  employeeId String
  attendedAt DateTime?
  status     String     @default("PENDING")
  feedback   String?
  rating     Int?
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  session    ILTSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, employeeId])
  @@index([sessionId])
  @@index([employeeId])
}

model Course {
  id              String                 @id @default(uuid())
  courseCode      String                 @unique
  title           String
  description     String?
  category        String
  duration        Int                    @default(60)
  passingScore    Int                    @default(70)
  isMandatory     Boolean                @default(false)
  status          CourseStatus           @default(DRAFT)
  createdBy       String?
  thumbnail       String?
  validityDays    Int?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  assignmentRules CourseAssignmentRule[]
  enrollments     CourseEnrollment[]
  feedbacks       CourseFeedback[]
  modules         CourseModule[]
  quiz            Quiz?

  @@index([status])
  @@index([category])
}

model CourseAssignmentRule {
  id        String   @id @default(uuid())
  courseId  String
  assignTo  String
  value     String
  dueDays   Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([assignTo])
}

model CourseModule {
  id         String  @id @default(uuid())
  courseId   String
  title      String
  content    String?
  videoUrl   String?
  duration   Int     @default(15)
  order      Int     @default(0)
  isRequired Boolean @default(true)
  course     Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Quiz {
  id           String         @id @default(uuid())
  courseId     String         @unique
  title        String         @default("Course Assessment")
  description  String?
  passingScore Int            @default(70)
  timeLimit    Int?
  maxAttempts  Int            @default(3)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts     QuizAttempt[]
  questions    QuizQuestion[]

  @@index([courseId])
}

model QuizQuestion {
  id           String       @id @default(uuid())
  quizId       String
  question     String
  questionType QuestionType @default(MULTIPLE_CHOICE)
  order        Int          @default(0)
  points       Int          @default(1)
  options      QuizOption[]
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizOption {
  id         String       @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean      @default(false)
  order      Int          @default(0)
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  employeeId  String
  score       Float?
  passed      Boolean?
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  answers     Json?
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([employeeId])
}

model CourseEnrollment {
  id          String           @id @default(uuid())
  courseId    String
  employeeId  String
  enrolledAt  DateTime         @default(now())
  enrolledBy  String?
  startedAt   DateTime?
  completedAt DateTime?
  dueDate     DateTime?
  score       Float?
  status      EnrollmentStatus @default(ENROLLED)
  attempts    Int              @default(0)
  certificate String?
  progress    Int              @default(0)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([courseId, employeeId])
  @@index([employeeId])
  @@index([courseId])
  @@index([status])
}

model CourseFeedback {
  id           String   @id @default(uuid())
  courseId     String
  employeeId   String
  enrollmentId String?
  rating       Int
  comment      String?
  submittedAt  DateTime @default(now())
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([courseId, employeeId])
  @@index([courseId])
  @@index([employeeId])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNo     String        @unique
  clientName    String
  clientEmail   String?
  clientAddress String?
  clientGST     String?
  companyId     String?
  billingMonth  Int
  billingYear   Int
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  subtotal      Float         @default(0)
  taxRate       Float         @default(18)
  taxAmount     Float         @default(0)
  totalAmount   Float         @default(0)
  paidAmount    Float         @default(0)
  notes         String?
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         InvoiceItem[]
  payments      Payment[]

  @@index([status])
  @@index([billingMonth, billingYear])
  @@index([createdAt])
}

model InvoiceItem {
  id            String  @id @default(uuid())
  invoiceId     String
  description   String
  employeeCount Int     @default(1)
  ratePerHead   Float
  days          Int     @default(26)
  amount        Float
  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String   @id @default(uuid())
  invoiceId   String
  amount      Float
  paymentDate DateTime
  paymentMode String
  referenceNo String?
  remarks     String?
  recordedBy  String
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Expense {
  id              String          @id @default(uuid())
  expenseNo       String          @unique
  title           String
  category        ExpenseCategory
  amount          Float
  date            DateTime
  description     String?
  receiptUrl      String?
  submittedBy     String
  employeeId      String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  paidAt          DateTime?
  paymentMode     String?
  status          ExpenseStatus   @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([submittedBy])
  @@index([date])
}

model ClientContract {
  id              String            @id @default(uuid())
  contractNo      String            @unique
  clientName      String
  clientCompanyId String?
  contactPerson   String?
  contactEmail    String?
  contactPhone    String?
  contractType    ContractType      @default(FIXED_TERM)
  status          ContractStatus    @default(DRAFT)
  startDate       DateTime
  endDate         DateTime?
  value           Float?
  monthlyValue    Float?
  manpowerCount   Int?
  serviceType     String?
  slaTerms        String?
  billingCycle    String?
  paymentTerms    String?
  notes           String?
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  renewals        ContractRenewal[]

  @@index([status])
  @@index([clientName])
  @@index([startDate])
}

model ContractRenewal {
  id         String         @id @default(uuid())
  contractId String
  renewedAt  DateTime       @default(now())
  newEndDate DateTime
  newValue   Float?
  notes      String?
  renewedBy  String
  contract   ClientContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model HRDocTemplate {
  id               String       @id @default(uuid())
  name             String
  type             String
  description      String?
  templateContent  String
  approvalRequired Boolean      @default(true)
  isActive         Boolean      @default(true)
  createdBy        String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  documents        HRDocument[]

  @@index([type])
  @@index([isActive])
}

model HRDocument {
  id              String          @id @default(uuid())
  docNumber       String          @unique
  templateId      String?
  employeeId      String
  type            String
  title           String
  content         String
  status          HRDocStatus     @default(DRAFT)
  effectiveDate   DateTime?
  issuedAt        DateTime?
  issuedBy        String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  acknowledgedAt  DateTime?
  emailSentAt     DateTime?
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  approvals       HRDocApproval[]
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  template        HRDocTemplate?  @relation(fields: [templateId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model HRDocApproval {
  id         String     @id @default(uuid())
  documentId String
  approverId String
  status     String     @default("PENDING")
  comments   String?
  actionAt   DateTime?
  createdAt  DateTime   @default(now())
  document   HRDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([approverId])
}

