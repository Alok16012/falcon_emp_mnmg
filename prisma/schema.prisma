generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String           @id @default(uuid())
  name                     String
  email                    String           @unique
  password                 String
  role                     Role             @default(CLIENT)
  phone                    String?
  image                    String?
  isActive                 Boolean          @default(true)
  createdAt                DateTime         @default(now())
  companyId                String?
  assignmentsAsAssigner    Assignment[]     @relation("AssignmentAssigner")
  assignmentsAsInspector   Assignment[]     @relation("AssignmentInspector")
  inspections              Inspection[]
  company                  Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  managedProjects          ProjectManager[] @relation("ProjectManagers")
  assignedProjects         ProjectManager[] @relation("ProjectManagerAssigner")
  notifications            Notification[]
  leadsAssigned            Lead[]           @relation("LeadAssignee")
  leadsCreated             Lead[]           @relation("LeadCreator")
  leadActivities           LeadActivity[]   @relation("LeadActivityUser")
}

model Company {
  id            String    @id @default(uuid())
  name          String
  address       String?
  contactPerson String?
  contactPhone  String?
  logoUrl       String?
  createdBy     String
  createdAt     DateTime  @default(now())
  projects      Project[]
  clients       User[]
}

model Project {
  id              String           @id @default(uuid())
  companyId       String
  name            String
  description     String?
  createdBy       String
  createdAt       DateTime         @default(now())
  assignments     Assignment[]
  formTemplates   FormTemplate[]
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectManagers ProjectManager[]
  defectColumns   Json?
  reportConfig    Json?
  alertConfig     AlertConfig?
}

model Assignment {
  id              String       @id @default(uuid())
  projectId       String
  inspectionBoyId String
  assignedBy      String
  status           String       @default("active")
  recurrenceType   String       @default("none")
  recurrenceActive Boolean      @default(false)
  createdAt        DateTime     @default(now())
  assigner         User         @relation("AssignmentAssigner", fields: [assignedBy], references: [id])
  inspectionBoy    User         @relation("AssignmentInspector", fields: [inspectionBoyId], references: [id])
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inspections      Inspection[]

  @@index([inspectionBoyId])
  @@index([projectId])
  @@index([status])
}

model Inspection {
  id             String           @id @default(uuid())
  assignmentId   String
  status         String           @default("draft")
  submittedAt    DateTime?
  createdAt      DateTime         @default(now())
  approvedAt     DateTime?
  approvedBy     String?
  reviewerNotes  String?
  submittedBy    String
  paperFormPhoto String?
  sentBackAt     DateTime?
  sentBackCount  Int              @default(0)
  gpsLocation    String?
  startedAt      DateTime?
  signature      String?
  assignment     Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submitter      User             @relation(fields: [submittedBy], references: [id])
  responses      InspectionData[]
  shareableLink  ShareableLink?

  @@index([status])
  @@index([assignmentId])
  @@index([submittedBy])
  @@index([submittedAt])
  @@index([approvedAt])
}

model InspectionData {
  id           String       @id @default(uuid())
  inspectionId String
  fieldId      String
  value        String?
  field        FormTemplate @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  inspection   Inspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([fieldId])
}

model FormTemplate {
  id           String           @id @default(uuid())
  projectId    String
  fieldLabel   String
  fieldType    String
  options      String?
  defaultValue String?
  isRequired   Boolean          @default(false)
  category     String           @default("FIXED")
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses    InspectionData[]

  @@index([projectId])
}

model ProjectManager {
  id         String   @id @default(uuid())
  projectId  String
  managerId  String
  assignedBy String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  manager    User     @relation("ProjectManagers", fields: [managerId], references: [id])
  assigner   User     @relation("ProjectManagerAssigner", fields: [assignedBy], references: [id])

  @@unique([projectId, managerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model ShareableLink {
  id           String     @id @default(uuid())
  inspectionId String     @unique
  token        String     @unique @default(uuid())
  expiresAt    DateTime?
  createdBy    String
  viewCount    Int        @default(0)
  createdAt    DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([token])
}

model AlertConfig {
  id              String   @id @default(uuid())
  projectId       String   @unique
  defectThreshold Float    @default(5.0)
  notifyManager   Boolean  @default(true)
  notifyAdmin     Boolean  @default(true)
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  MANAGER
  INSPECTION_BOY
  CLIENT
}

enum LeadStatus {
  APPLIED
  SCREENING
  INTERVIEW_SCHEDULED
  INTERVIEW_DONE
  SELECTED
  ONBOARDED
  REJECTED
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

model Lead {
  id             String        @id @default(uuid())
  candidateName  String
  phone          String
  email          String?
  city           String?
  position       String        // Role applied for e.g. Inspector, Security Guard, Supervisor
  experience     Float?        // Years of experience
  currentCompany String?       // Previous/current employer
  qualification  String?       // 10th, 12th, Graduate, ITI, Diploma, etc.
  skills         String?       // Driving License, Forklift, First Aid, etc.
  expectedSalary Float?
  currentSalary  Float?
  interviewDate  DateTime?
  interviewMode  String?       // In-person, Phone, Video
  source         String        // Walk-in, LinkedIn, Naukri, Referral, WhatsApp, Agency, Indeed
  status         LeadStatus    @default(APPLIED)
  priority       LeadPriority  @default(MEDIUM)
  assignedTo     String?
  notes          String?
  nextFollowUp   DateTime?
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  assignee       User?         @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator        User          @relation("LeadCreator", fields: [createdBy], references: [id])
  activities     LeadActivity[]

  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  type      String   // note, call, email, meeting, whatsapp, status_change
  content   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation("LeadActivityUser", fields: [userId], references: [id])

  @@index([leadId])
}
